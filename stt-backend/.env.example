# STT/TTS Backend Configuration
VCB_HOST=0.0.0.0
VCB_PORT=8766
VCB_AUTH_TOKEN=

# STT Settings
STT_MODEL_SIZE=medium
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8
STT_PARTIAL_INTERVAL_SEC=1.0

# TTS Settings (auto|off|piper|say)
TTS_MODE=auto
PIPER_BIN=piper
PIPER_MODEL=

# LLM (optional — only needed for standalone mode)
OPENCLAW_BIN=openclaw
CODEX_BIN=codex
CODEX_MODEL=
CODEX_WARMUP=1
