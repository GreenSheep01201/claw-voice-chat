# STT/TTS Backend Configuration
VCB_HOST=0.0.0.0
VCB_PORT=8766
VCB_AUTH_TOKEN=

# STT Settings
STT_MODEL_SIZE=medium
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8
STT_PARTIAL_INTERVAL_SEC=1.0
# Force a specific Whisper language (ISO 639-1: pt, es, fr, ja, …). Empty = auto-detect.
# The frontend can also override per-session via the ?language= query param.
VCB_STT_LANGUAGE=

# TTS Settings (auto|off|piper|say|sapi)
TTS_MODE=auto
PIPER_BIN=piper
PIPER_MODEL=
# Windows SAPI voice name (e.g. "Microsoft Maria Desktop"). Empty = pick the
# first installed voice matching the current culture (falls back to system default).
VCB_SAPI_VOICE_NAME=

# LLM (optional — only needed for standalone mode)
OPENCLAW_BIN=openclaw
CODEX_BIN=codex
CODEX_MODEL=
CODEX_WARMUP=1
