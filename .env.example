# ── Claw-Voice-Chat Environment Variables ──
# Copy this file to .env and edit the values.
#   cp .env.example .env

# ── Server ──
PORT=8888
NODE_ENV=production

# ── STT/TTS Backend (Python FastAPI — included in stt-backend/) ──
# Push-to-talk voice input (STT) and audio TTS playback.
# Install: npm run stt:install
# Start:   npm run stt:start
VCB_BACKEND_HTTP=http://127.0.0.1:8766

# STT model size: tiny, base, small, medium, large-v3
# Larger = more accurate but slower and uses more memory.
STT_MODEL_SIZE=medium
# STT device: auto, cpu, cuda
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8

# ── Channel Bridge (OpenClaw Gateway) ──
# Required to connect to Telegram, Discord, and other OpenClaw channels.
# Run: npm install -g openclaw && openclaw gateway run
# Token: found in ~/.openclaw/openclaw.json → gateway.auth.token
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# ── Model Catalog ──
# Path to the openclaw CLI binary. Used to list available models.
# If openclaw is in your PATH, just set: OPENCLAW_CLI=openclaw
OPENCLAW_CLI=
